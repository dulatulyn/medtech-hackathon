DB_USER=postgres
DB_PASSWORD=postgres
DB_HOST=db
DB_PORT=5432
DB_NAME=nn

SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OCR for scanned PDFs — Azure Document Intelligence (prebuilt-read).
# Leave blank to run infra-light (scans -> needs_review). Region is encoded in the endpoint URL.
OCR_AZURE_ENDPOINT=
OCR_AZURE_KEY=

# Meilisearch full-text search (optional; blank disables /search/full).
MEILI_URL=
MEILI_KEY=

# Local embeddings for semantic search (multilingual-e5-large, 1024-dim).
EMBED_MODEL=intfloat/multilingual-e5-large
EMBED_ENABLED=true